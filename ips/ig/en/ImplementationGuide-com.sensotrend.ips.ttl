  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\"><p class=\"res-header-id\"><b>Generated Narrative: ImplementationGuide com.sensotrend.ips</b></p><a name=\"com.sensotrend.ips\"> </a><a name=\"hccom.sensotrend.ips\"> </a><div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\"><p style=\"margin-bottom: 0px\">Language: en</p></div><h2>SensotrendIPS</h2><p>The official URL for this implementation guide is: </p><pre>https://ips.sensotrend.com/ig/ImplementationGuide/com.sensotrend.ips</pre><div><p>This document describes Sensotrend's implementation of the <a href=\"https://hl7.org/fhir/uv/ips/\">HL7 FHIR IPS</a> format of the <a href=\"https://international-patient-summary.net/\">International Patient Summary (IPS)</a> specification both as a client app and as a FHIR server. It also includes and extensive example patient summary for Mikael, an example patient.</p>\n</div></div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:url [
     fhir:v "https://ips.sensotrend.com/ig/ImplementationGuide/com.sensotrend.ips"^^xsd:anyURI ;
     fhir:l <https://ips.sensotrend.com/ig/ImplementationGuide/com.sensotrend.ips>
  ] ; # 
  fhir:version [ fhir:v "0.3.0"] ; # 
  fhir:name [ fhir:v "SensotrendIPS"] ; # 
  fhir:title [ fhir:v "Sensotrend's International Patient Summary Implementation"] ; # 
  fhir:status [ fhir:v "active"] ; # 
  fhir:date [ fhir:v "2026-05-22T17:00:00+03:00"^^xsd:dateTime] ; # 
