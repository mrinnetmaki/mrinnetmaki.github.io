  fhir:note ( [
     fhir:author [
       a fhir:Reference ;
       fhir:l <urn:uuid:b4ac89c5-6589-417f-beef-d3fb1ef9c70f> ;
       fhir:reference [ fhir:v "urn:uuid:b4ac89c5-6589-417f-beef-d3fb1ef9c70f" ] ;
       fhir:display [ fhir:v "Mikael Rinnetmäki, the patient" ]
     ] ;
     fhir:text [ fhir:v "I disagree with this diagnosis. The earlier diagnosis of dysphonia due to vocal cord problems is correct. For this diagnosis, I got a prescription for reflux medication, which I did not get. For the earlier diagnosis, I was supposed to get voice therapy, but got this other diagnosis instead. What actually helped was that I started to sing in a choir. Whenever I take a longer break from singing, the symptoms come back. When I start singing again, the symptoms go away." ]
