     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: Condition 14534413-2ea5-4988-9f2a-a7f6c6059353</b></p><a name=\"14534413-2ea5-4988-9f2a-a7f6c6059353\"> </a><a name=\"hc14534413-2ea5-4988-9f2a-a7f6c6059353\"> </a><div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\"><p style=\"margin-bottom: 0px\"/><p style=\"margin-bottom: 0px\">Profiles: <a href=\"http://hl7.org/fhir/uv/ipa/STU1.1/StructureDefinition-ipa-condition.html\">IPA-Condition</a> version: 1.1.0, <a href=\"http://hl7.org/fhir/uv/ips/STU2/StructureDefinition-Condition-uv-ips.html\">Condition (IPS)</a>, <a href=\"http://hl7.eu/fhir/base/2.0.0/StructureDefinition-condition-eu-core.html\">Condition (EU core)</a>, <a href=\"https://build.fhir.org/ig/hl7-eu/eps/StructureDefinition-condition-obl-eu-eps.html\">Condition - Obligations (EPS)</a></p><p style=\"margin-bottom: 0px\">Security Labels: <a href=\"http://hl7.org/fhir/R4/v3/ObservationValue/cs.html\">device reported (Details: v3 Code System ObservationValue code DEVRPT = 'device reported')</a>, <a href=\"http://hl7.org/fhir/R4/v3/ObservationValue/cs.html\">patient reported (Details: v3 Code System ObservationValue code PATRPT = 'patient reported')</a>, <a href=\"http://hl7.org/fhir/R4/v3/ObservationValue/cs.html\">syntactic transform (Details: v3 Code System ObservationValue code SYNTAC = 'syntactic transform')</a>, <a href=\"http://hl7.org/fhir/R4/v3/ObservationValue/cs.html\">mapped (Details: v3 Code System ObservationValue code MAPPED = 'mapped')</a>, <a href=\"http://hl7.org/fhir/R4/v3/ObservationValue/cs.html\">patient asserted (Details: v3 Code System ObservationValue code PATAST = 'patient asserted')</a></p></div><p><b>clinicalStatus</b>: <span title=\"Codes:{http://terminology.hl7.org/CodeSystem/condition-clinical resolved}\">Resolved</span></p><p><b>verificationStatus</b>: <span title=\"Codes:{http://terminology.hl7.org/CodeSystem/condition-ver-status confirmed}\">Confirmed</span></p><p><b>category</b>: <span title=\"Codes:{http://terminology.hl7.org/CodeSystem/condition-category encounter-diagnosis}\">Encounter Diagnosis</span></p><p><b>severity</b>: <span title=\"Codes:{http://snomed.info/sct 6736007}\">Moderate</span></p><p><b>code</b>: <span title=\"Codes:{http://snomed.info/sct 60600009}, {http://hl7.org/fhir/sid/icd-10 J38.7}\">Muu kurkunpään sairaus (other diseases of larynx)</span></p><p><b>subject</b>: <a href=\"Bundle-IpsBundle.html#urn-uuid-b4ac89c5-6589-417f-beef-d3fb1ef9c70f\">Mikael Rinnetmäki</a></p><p><b>onset</b>: 2016-06-14</p><p><b>asserter</b>: Kleemola, Leenamaija</p><p><b>note</b>: By urn:uuid:b4ac89c5-6589-417f-beef-d3fb1ef9c70f</p><blockquote><div><p>I disagree with this diagnosis. The earlier diagnosis of dysphonia due to vocal cord problems is correct. For this diagnosis, I got a prescription for reflux medication, which I did not get. For the earlier diagnosis, I was supposed to get voice therapy, but got this other diagnosis instead. What actually helped was that I started to sing in a choir. Whenever I take a longer break from singing, the symptoms come back. When I start singing again, the symptoms go away.</p>\n</div></blockquote></div>"^^rdf:XMLLiteral ]
