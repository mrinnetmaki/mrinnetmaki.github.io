       fhir:reference [ fhir:v "urn:uuid:bb2d0be6-24fd-4e1f-8fa4-10e058ed2775" ] ;
       fhir:display [ fhir:v "Insulin NovoRapid 100 units/ml. My prescription is for 50 - 100 iU/d. I usually consume 40 to 70 iU per day." ]
     ] [
       fhir:l <urn:uuid:f3f4ff44-62be-440c-9e79-1a5de2d64016> ;
       fhir:reference [ fhir:v "urn:uuid:f3f4ff44-62be-440c-9e79-1a5de2d64016" ] ;
       fhir:display [ fhir:v "Rosuvastatin 10 mg. Started with 5mg in 2022, dose set to 10mg late 2024." ]
     ] [
       fhir:l <urn:uuid:17725642-fd58-4f71-a9e6-1dee30e048bf> ;
       fhir:reference [ fhir:v "urn:uuid:17725642-fd58-4f71-a9e6-1dee30e048bf" ] ;
       fhir:display [ fhir:v "Ezetimibe 10 mg. I know I should be taking both rosuvastatin and ezetimibe in the evening, but I take them in the morning, because that's when I remember to take them. My doctor knows this, and approves." ]
     ] )
  ] [
