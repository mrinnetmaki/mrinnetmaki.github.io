       fhir:display [ fhir:v "2020-08-20 Problems with shoulder mobility" ]
     ] [
       fhir:l <urn:uuid:ead8fa45-4c6b-47b5-876b-6c01090d2c49> ;
       fhir:reference [ fhir:v "urn:uuid:ead8fa45-4c6b-47b5-876b-6c01090d2c49" ] ;
       fhir:display [ fhir:v "2017-11-20 Fractured left ring finger" ]
     ] [
       fhir:l <urn:uuid:14534413-2ea5-4988-9f2a-a7f6c6059353> ;
       fhir:reference [ fhir:v "urn:uuid:14534413-2ea5-4988-9f2a-a7f6c6059353" ] ;
       fhir:display [ fhir:v "2016-06-14 Disputed diagnosis of disease in larynx" ]
     ] [
       fhir:l <urn:uuid:af227524-ca64-46ed-8aad-c17f1a712af5> ;
       fhir:reference [ fhir:v "urn:uuid:af227524-ca64-46ed-8aad-c17f1a712af5" ] ;
       fhir:display [ fhir:v "2016-05-13 Myopia" ]
     ] [
       fhir:l <urn:uuid:d621ec37-44d1-455a-9f95-b62ee1e6f7f1> ;
       fhir:reference [ fhir:v "urn:uuid:d621ec37-44d1-455a-9f95-b62ee1e6f7f1" ] ;
       fhir:display [ fhir:v "2016-05-06 Dysphonia due to vocal cord problems" ]
     ] )
  ] [
     fhir:title [ fhir:v "Patient Story" ] ;
     fhir:code [
       fhir:coding ( [
         a loinc:81338-6 ;
         fhir:system [
           fhir:v "http://loinc.org"^^xsd:anyURI ;
           fhir:l <http://loinc.org>
         ] ;
         fhir:code [ fhir:v "81338-6" ] ;
         fhir:display [ fhir:v "Patient Goals, preferences, and priorities for care experience" ]
       ] )
     ] ;
     fhir:text [
       fhir:status [ fhir:v "additional" ] ;
       fhir:div [ fhir:v "<div xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\">Regarding my type 1 diabetes, I consider myself an independent and empowered patient. Diabetes forces me to take care of myself, but I still often prioritize the things I want to achieve in life over my own short-term health and well-being.</div>"^^rdf:XMLLiteral ]
     ] ;
     fhir:emptyReason [
       fhir:coding ( [
         fhir:system [
           fhir:v "http://terminology.hl7.org/CodeSystem/list-empty-reason"^^xsd:anyURI ;
           fhir:l <http://terminology.hl7.org/CodeSystem/list-empty-reason>
         ] ;
         fhir:code [ fhir:v "notstarted" ] ;
         fhir:display [ fhir:v "Not Started" ]
       ] )
     ]
  ] [
     fhir:title [ fhir:v "Plan of Care" ] ;
     fhir:code [
       fhir:coding ( [
         a loinc:18776-5 ;
         fhir:system [
           fhir:v "http://loinc.org"^^xsd:anyURI ;
           fhir:l <http://loinc.org>
         ] ;
         fhir:code [ fhir:v "18776-5" ] ;
         fhir:display [ fhir:v "Plan of care note" ]
       ] )
     ] ;
     fhir:text [
       fhir:status [ fhir:v "additional" ] ;
       fhir:div [ fhir:v "<div xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\">My primary contact to healthcare is through occupational healthcare, currently organized by Terveystalo, previously by Mehiläinen. For diabetes related things I turn to my endocrinologist, whom I nowadays meet every other year.</div>"^^rdf:XMLLiteral ]
     ] ;
     fhir:emptyReason [
       fhir:coding ( [
         fhir:system [
           fhir:v "http://terminology.hl7.org/CodeSystem/list-empty-reason"^^xsd:anyURI ;
           fhir:l <http://terminology.hl7.org/CodeSystem/list-empty-reason>
         ] ;
         fhir:code [ fhir:v "notstarted" ] ;
         fhir:display [ fhir:v "Not Started" ]
       ] )
     ]
  ] [
     fhir:title [ fhir:v "Social History" ] ;
     fhir:code [
       fhir:coding ( [
         a loinc:29762-2 ;
         fhir:system [
           fhir:v "http://loinc.org"^^xsd:anyURI ;
           fhir:l <http://loinc.org>
         ] ;
         fhir:code [ fhir:v "29762-2" ] ;
         fhir:display [ fhir:v "Social history note" ]
       ] )
     ] ;
     fhir:text [
       fhir:status [ fhir:v "additional" ] ;
       fhir:div [ fhir:v "<div xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\">I've never smoked. I consume alcohol in moderation, less than once a month and never more than 6 servings at a time.</div>"^^rdf:XMLLiteral ]
     ] ;
     fhir:entry ( [
       fhir:l <urn:uuid:ec8d3ccb-d68c-433f-8db7-5bf1fcaf0328> ;
       fhir:reference [ fhir:v "urn:uuid:ec8d3ccb-d68c-433f-8db7-5bf1fcaf0328" ] ;
       fhir:display [ fhir:v "Never smoker" ]
     ] [
       fhir:l <urn:uuid:432d2590-6b3a-4e3f-b38c-6a0cc8dc9243> ;
       fhir:reference [ fhir:v "urn:uuid:432d2590-6b3a-4e3f-b38c-6a0cc8dc9243" ] ;
       fhir:display [ fhir:v "Drink about once per month, one to three doses per time" ]
     ] )
  ] [
     fhir:title [ fhir:v "Vital Signs" ] ;
     fhir:code [
       fhir:coding ( [
         a loinc:8716-3 ;
         fhir:system [
           fhir:v "http://loinc.org"^^xsd:anyURI ;
           fhir:l <http://loinc.org>
         ] ;
         fhir:code [ fhir:v "8716-3" ] ;
         fhir:display [ fhir:v "Vital signs note" ]
       ] )
     ] ;
     fhir:text [
       fhir:status [ fhir:v "additional" ] ;
       fhir:div [ fhir:v "<div xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\">I'm 186 cm (6 ft 1 in) tall and weigh about 80 kg (175 lb, or 12 st 8 lb). My blood pressure is usually 110-120 / 65-70 mmHg.</div>"^^rdf:XMLLiteral ]
     ] ;
     fhir:entry ( [
       fhir:l <urn:uuid:55e62594-fc71-4437-ad8c-13acaf51d2cd> ;
