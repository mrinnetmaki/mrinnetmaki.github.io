       fhir:div [ fhir:v "<div xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\">I have no known medication related allergies. I'm mildly allergic to apple, birch pollen, and some nuts.</div>"^^rdf:XMLLiteral ]
