       fhir:reference [ fhir:v "urn:uuid:25ba5f1a-90b3-49a8-a251-ac402bb4ccc8" ] ;
       fhir:display [ fhir:v "Use of the Abbott Freestyle Libre 3 continuous glucose monitoring (CGM) system since November 30, 2024" ]
     ] )
  ] [
     fhir:title [ fhir:v "Advance Directives" ] ;
     fhir:code [
       fhir:coding ( [
         a loinc:42348-3 ;
         fhir:system [
           fhir:v "http://loinc.org"^^xsd:anyURI ;
           fhir:l <http://loinc.org>
         ] ;
         fhir:code [ fhir:v "42348-3" ] ;
         fhir:display [ fhir:v "Advance healthcare directives" ]
       ] )
     ] ;
     fhir:text [
       fhir:status [ fhir:v "additional" ] ;
       fhir:div [ fhir:v "<div xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\"><p>I generally trust my automated insulin delivery system. If possible, I prefer to wear it even when unconsious, rather than having someone administer insulin by a fixed or estimated scale.</p><p>I'm driven and have many things still to achieve, and prefer to be resuscitated if there is a chance for me to become capable of interacting with the world.</p><p>In case of death, I am willing to donate my organs for whatever purpose.</p><p>Since I have a history of using automated insulin delivery systems developed by an open-source development community, in the case of my passing away I'd like it to be communicated whether the use of such a system played any role in the event.</p><p>Regarding my data, including all information in this document, I consent to it being used for my treatment, including with AI based decision support tools, and to it being stored to electronic health record systems. I also consent to this information being used for training of healthcare professionals and for machine learning training <strong>in de-identified form only</strong>.</p></div>"^^rdf:XMLLiteral ]
     ] ;
     fhir:entry ( [
       fhir:l <urn:uuid:8d139b91-6567-4372-9329-0a2faf7cae99> ;
       fhir:reference [ fhir:v "urn:uuid:8d139b91-6567-4372-9329-0a2faf7cae99" ] ;
       fhir:display [ fhir:v "Advance directives for treatment" ]
     ] [
       fhir:l <urn:uuid:fc6ca80d-ce07-47d9-a1c0-49e955ae166b> ;
       fhir:reference [ fhir:v "urn:uuid:fc6ca80d-ce07-47d9-a1c0-49e955ae166b" ] ;
       fhir:display [ fhir:v "Deny the use of my data for marketing" ]
     ] [
       fhir:l <urn:uuid:c67f1ac1-5013-47dc-88ad-73d8eca510b0> ;
       fhir:reference [ fhir:v "urn:uuid:c67f1ac1-5013-47dc-88ad-73d8eca510b0" ] ;
       fhir:display [ fhir:v "Deny the use of my re-identifiable data for machine learning training" ]
     ] [
       fhir:l <urn:uuid:0b8b4bfe-12e8-4dcc-9299-27fd76e464ce> ;
       fhir:reference [ fhir:v "urn:uuid:0b8b4bfe-12e8-4dcc-9299-27fd76e464ce" ] ;
       fhir:display [ fhir:v "Consent for the use of my data in healthcare" ]
     ] [
       fhir:l <urn:uuid:e7fd44af-ae28-4994-a04f-37d8e52864a1> ;
       fhir:reference [ fhir:v "urn:uuid:e7fd44af-ae28-4994-a04f-37d8e52864a1" ] ;
       fhir:display [ fhir:v "Consent for the use of my de-identified data for research" ]
     ] )
  ] [
     fhir:title [ fhir:v "Alerts" ] ;
     fhir:code [
       fhir:coding ( [
         a loinc:104605-1 ;
         fhir:system [
           fhir:v "http://loinc.org"^^xsd:anyURI ;
           fhir:l <http://loinc.org>
         ] ;
         fhir:code [ fhir:v "104605-1" ] ;
         fhir:display [ fhir:v "Alert" ]
       ] )
     ] ;
     fhir:text [
       fhir:status [ fhir:v "additional" ] ;
       fhir:div [ fhir:v "<div xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\">Nothing to alert at the moment.</div>"^^rdf:XMLLiteral ]
     ] ;
     fhir:emptyReason [
       fhir:coding ( [
         fhir:system [
           fhir:v "http://terminology.hl7.org/CodeSystem/list-empty-reason"^^xsd:anyURI ;
           fhir:l <http://terminology.hl7.org/CodeSystem/list-empty-reason>
         ] ;
         fhir:code [ fhir:v "nilknown" ] ;
         fhir:display [ fhir:v "Nil Known" ]
       ] )
     ]
  ] [
     fhir:title [ fhir:v "Functional Status" ] ;
     fhir:code [
       fhir:coding ( [
         a loinc:47420-5 ;
         fhir:system [
           fhir:v "http://loinc.org"^^xsd:anyURI ;
           fhir:l <http://loinc.org>
         ] ;
         fhir:code [ fhir:v "47420-5" ] ;
         fhir:display [ fhir:v "Functional status assessment note" ]
       ] )
     ] ;
     fhir:text [
       fhir:status [ fhir:v "additional" ] ;
       fhir:div [ fhir:v "<div xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\">I have no disabilities. I don't think I have any real records of functional status assessments performed by a clinician. Personally, I feel I'm in relatively good health and in relatively good condition. I can do what I want to do.</div>"^^rdf:XMLLiteral ]
     ] ;
     fhir:emptyReason [
       fhir:coding ( [
         fhir:system [
           fhir:v "http://terminology.hl7.org/CodeSystem/list-empty-reason"^^xsd:anyURI ;
           fhir:l <http://terminology.hl7.org/CodeSystem/list-empty-reason>
         ] ;
         fhir:code [ fhir:v "nilknown" ] ;
         fhir:display [ fhir:v "Nil Known" ]
       ] )
     ]
  ] [
     fhir:title [ fhir:v "History of Past Problems" ] ;
     fhir:code [
       fhir:coding ( [
         a loinc:11348-0 ;
         fhir:system [
           fhir:v "http://loinc.org"^^xsd:anyURI ;
           fhir:l <http://loinc.org>
         ] ;
         fhir:code [ fhir:v "11348-0" ] ;
         fhir:display [ fhir:v "History of Past illness note" ]
       ] )
     ] ;
     fhir:text [
       fhir:status [ fhir:v "additional" ] ;
       fhir:div [ fhir:v "<div xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\">I have had, and still occasionally have problems with mobility of my right shoulder. I've suffered a pulmonary embolism event in 2022. I have had many of my bones broken in various accidents.</div>"^^rdf:XMLLiteral ]
     ] ;
     fhir:mode [ fhir:v "working" ] ;
     fhir:orderedBy [
       fhir:coding ( [
         fhir:system [
           fhir:v "http://terminology.hl7.org/CodeSystem/list-order"^^xsd:anyURI ;
           fhir:l <http://terminology.hl7.org/CodeSystem/list-order>
         ] ;
         fhir:code [ fhir:v "event-date" ] ;
         fhir:display [ fhir:v "Sorted by Event Date" ]
       ] )
     ] ;
     fhir:entry ( [
       fhir:l <urn:uuid:1e591fa2-f118-4ef4-9103-9b9fe5d3da75> ;
       fhir:reference [ fhir:v "urn:uuid:1e591fa2-f118-4ef4-9103-9b9fe5d3da75" ] ;
       fhir:display [ fhir:v "2024-11-03 Fractured left collarbone" ]
     ] [
       fhir:l <urn:uuid:2c4dc13c-2927-4cd7-b86e-1a3b89493d2b> ;
       fhir:reference [ fhir:v "urn:uuid:2c4dc13c-2927-4cd7-b86e-1a3b89493d2b" ] ;
       fhir:display [ fhir:v "2022-10-23Pulmonary embolism" ]
     ] [
       fhir:l <urn:uuid:22e07a7b-4d9b-406d-93bc-dc60de933f1f> ;
