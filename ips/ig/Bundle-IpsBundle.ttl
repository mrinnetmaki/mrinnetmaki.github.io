     fhir:text [
       fhir:status [ fhir:v "additional" ] ;
       fhir:div [ fhir:v "<div xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\">I use insulin (NovoRapid) for diabetes, and rosuvastatin and ezetimibe for diabetes related hypercholesterolemia.</div>"^^rdf:XMLLiteral ]
     ] ;
     fhir:mode [ fhir:v "working" ] ;
     fhir:orderedBy [
