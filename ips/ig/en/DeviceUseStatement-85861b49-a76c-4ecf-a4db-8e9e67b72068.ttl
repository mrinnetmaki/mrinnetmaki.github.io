     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: DeviceUseStatement 85861b49-a76c-4ecf-a4db-8e9e67b72068</b></p><a name=\"85861b49-a76c-4ecf-a4db-8e9e67b72068\"> </a><a name=\"hc85861b49-a76c-4ecf-a4db-8e9e67b72068\"> </a><div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\"><p style=\"margin-bottom: 0px\"/><p style=\"margin-bottom: 0px\">Profiles: <a href=\"http://hl7.org/fhir/uv/ips/STU2/StructureDefinition-DeviceUseStatement-uv-ips.html\">DeviceUseStatement (IPS)</a>, <a href=\"https://build.fhir.org/ig/hl7-eu/eps/StructureDefinition-deviceUseStatement-eu-eps.html\">DeviceUseStatement (EPS)</a></p><p style=\"margin-bottom: 0px\">Security Labels: <a href=\"http://hl7.org/fhir/R4/v3/ObservationValue/cs.html\">patient reported (Details: v3 Code System ObservationValue code PATRPT = 'patient reported')</a>, <a href=\"http://hl7.org/fhir/R4/v3/ObservationValue/cs.html\">patient asserted (Details: v3 Code System ObservationValue code PATAST = 'patient asserted')</a></p></div><p><b>status</b>: Active</p><p><b>subject</b>: <a href=\"Bundle-IpsBundle.html#urn-uuid-b4ac89c5-6589-417f-beef-d3fb1ef9c70f\">Mikael Rinnetmäki</a></p><p><b>timing</b>: 2023-10-06 --&gt; 2024-11-30</p><p><b>recordedOn</b>: 2023-12-27</p><p><b>source</b>: <a href=\"Bundle-IpsBundle.html#urn-uuid-b4ac89c5-6589-417f-beef-d3fb1ef9c70f\">Mikael Rinnetmäki, the patient</a></p><p><b>device</b>: <a href=\"Bundle-IpsBundle.html#urn-uuid-876781b9-0db0-429a-877b-23e17e4d8443\">Dexcom G6 continuous glucose monitoring (CGM) system</a></p><p><b>reasonCode</b>: <span title=\"Codes:{http://snomed.info/sct 46635009}\">Type 1 diabetes mellitus</span></p><p><b>reasonReference</b>: <a href=\"Bundle-IpsBundle.html#urn-uuid-1558c456-efa1-4b3d-abe2-1522c6048bc7\">Type 1 diabetes mellitus</a></p><p><b>note</b>: By urn:uuid:b4ac89c5-6589-417f-beef-d3fb1ef9c70f</p><blockquote><div><p>I switched from Dexcom G6 CGM to Abbott Freestyle Libre 3+ in November 2024, but still use Dexcom occasionally. I find Dexcom sensors to be more accurate. Libre tends to show lower readings for me, compared to fingerstick measurements (with all glucometers I've tried).</p>\n</div></blockquote></div>"^^rdf:XMLLiteral ]
